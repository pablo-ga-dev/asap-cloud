---
const links = [
  { href: "/", label: "Inicio" },
  { href: "/services", label: "Servicios" },
  { href: "/about", label: "Nosotros" },
  { href: "/contact", label: "Contacto" },
];
---

<header class="border-b border-gray-200">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <!-- Logo -->
    <a href="/" class="text-xl font-bold text-slate-900">
      ASAP CLOUD
    </a>

    <!-- Navegación -->
    <ul class="flex items-center gap-8">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-slate-700 transition-colors duration-200 hover:text-blue-600"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
