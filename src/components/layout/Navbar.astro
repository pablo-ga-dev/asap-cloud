---
import SessionButton from "../ui/SessionButton.astro";
import Logo from "../ui/Logo.astro";
const links = [
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header
  class="fixed top-0 w-full z-50 pointer-events-none animate-fade-in-down animate-delay-1000 animate-duration-1000"
>
  <nav
    class="grid grid-cols-3 items-center mx-auto h-16 px-4 text-white mix-blend-difference pointer-events-auto"
  >
    <a
      href="/"
      class="text-xl font-bold w-10 text-white hover:text-accent-300 transition duration-300"
    >
      <Logo />
    </a>

    <!-- Navegación -->
    <ul class="flex items-center justify-center gap-8">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-m font-light tracking-wide transition duration-300 group relative"
            >
              {link.label}
              <span class="absolute -bottom-1 left-0 h-px w-full scale-x-0 bg-white transition-transform duration-300 ease-out group-hover:scale-x-100" />
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex justify-end">
      <SessionButton />
    </div>
  </nav>
</header>
