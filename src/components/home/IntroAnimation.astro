---

---

<div id="intro-shell" class="relative w-full">
  <div
    id="stage"
    class="fixed inset-0 z-40 flex items-center justify-center overflow-hidden bg-black text-white"
  >
    <span
      id="left-bottom-word"
      class="animate-fade-in-up animate-delay-1000 animate-duration-1000 pointer-events-none absolute bottom-4 left-5 text-[clamp(2.4rem,10vw,10rem)] font-medium leading-none tracking-tight text-white font-['Cabinet_Grotesk'] md:bottom-8 md:left-8"
      >ASAP</span
    >
    <span
      id="right-bottom-word"
      class="animate-fade-in-up animate-delay-1000 animate-duration-1000 pointer-events-none absolute bottom-4 right-5 text-[clamp(2.4rem,10vw,10rem)] font-medium leading-none tracking-tight text-white font-['Cabinet_Grotesk'] md:bottom-8 md:right-8"
      >CLOUD</span
    >
    <div id="wrapper" class="flex h-screen w-full items-center justify-center">
      <div
        id="card-container"
        class="flex overflow-hidden"
        style="--square-side: clamp(9rem, 26vmin, 18rem); width: calc(var(--square-side) * 2); height: var(--square-side);"
      >
        <div
          id="left-card"
          class="relative h-full flex-1 bg-white text-black animate-slide-in-top animate-duration-1000"
        >
          <div
            id="left-main-text-wrapper"
            class="absolute left-0 top-0 p-4 md:p-4 overflow-hidden"
          >
            <span
              id="left-main-text"
              class="text-xl font-semibold inline-block animate-fade-in-down animate-duration-1000"
              >Fast-Track</span
            >
          </div>
        </div>

        <div
          id="right-card"
          class="relative h-full flex-1 bg-accent-300 text-black animate-slide-in-bottom animate-duration-1000"
        >
          <div
            id="right-main-text-wrapper"
            class="absolute bottom-0 right-0 p-4 md:p-4 overflow-hidden"
          >
            <span
              id="right-main-text"
              class="text-xl font-semibold inline-block animate-fade-in-up animate-duration-1000"
              >Secure Reality</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>
  <div id="scroll-spacer" class="h-[220vh] w-full" aria-hidden="true"></div>
</div>

<script>
  import  "../../features/home/introAnimation.ts";
</script>
